# ── Database ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=rootpassword
DB_NAME=name_change_db

# ── Google APIs ────────────────────────────────────────
# Path to your Google service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=./config/google-credentials.json
# From Google Cloud Console → Document AI → Your processor
GOOGLE_DOCUMENT_AI_PROJECT_ID=your-gcp-project-id
GOOGLE_DOCUMENT_AI_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=your-processor-id

# ── Gemini ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── LangSmith (optional but recommended) ──────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=name-change-verification

# ── S3 / MinIO ─────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=name-change-docs

# ── App ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# ── Mock Mode (no Google/Gemini keys needed) ───────────
# Set true to run with synthetic data for local UI dev
MOCK_PIPELINE=true

# ── Chroma Vector DB ───────────────────────────────────
# docker run -p 8000:8000 chromadb/chroma
CHROMA_URL=http://localhost:8000
