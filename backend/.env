# ── Gemini ─────────────────────────────────────────────
GEMINI_API_KEY=AIzaSyD146h7XaX5gc_484hT8SkmlQzHNcLrA3M

# ── LangSmith (optional but recommended) ──────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=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
LANGCHAIN_PROJECT=name-change-verification

# ── S3 / MinIO ─────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
